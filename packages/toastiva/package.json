{
  "name": "toastiva",
  "version": "0.1.6",
  "description": "Morphing toast notifications for React Native and React Native Web.",
  "license": "MIT",
  "author": "Ritesh <119659853+rit3zh@users.noreply.github.com>",
  "homepage": "https://github.com/rit3zh/expo-gooey-toast#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rit3zh/expo-gooey-toast.git",
    "directory": "packages/toastiva"
  },
  "bugs": {
    "url": "https://github.com/rit3zh/expo-gooey-toast/issues"
  },
  "keywords": [
    "expo",
    "react-native",
    "react-native-web",
    "toast",
    "notifications",
    "reanimated",
    "gesture-handler"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "react-native": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.mjs",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf dist",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run typecheck"
  },
  "peerDependencies": {
    "expo-blur": ">=14",
    "react": ">=18",
    "react-native": ">=0.72",
    "react-native-gesture-handler": ">=2",
    "react-native-reanimated": ">=3 <5",
    "react-native-safe-area-context": ">=4",
    "react-native-svg": ">=13"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "expo-blur": "~55.0.12",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.4",
    "tsup": "^8.5.1",
    "typescript": "~5.9.2"
  }
}
